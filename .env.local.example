# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Use either legacy anon JWT or new publishable key (Connect dialog / API Keys)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# App (fallback when request Host headers are unavailable; signup email links use window.location.origin)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=DuckPass

# Supabase → Authentication → URL Configuration (required for email links to work):
# - Site URL: match how you open the app (localhost, 127.0.0.1, or your tunnel origin)
# - Redirect URLs: add every origin you use, e.g.:
#   http://localhost:3000/**
#   http://127.0.0.1:3000/**
#   https://YOUR-SUBDOMAIN.ngrok-free.dev/**
#   ...plus production when deployed.
# Tunnels (ngrok): also ensure next.config.ts allowedDevOrigins includes *.ngrok-free.dev (already in repo).

# Optional: salt for hashing client IPs in scan_events (see migrations/005_scan_events_privacy.sql)
# SCAN_IP_SALT=your-random-string

# PWA: service worker registers in production only (public/sw.js). Replace public/icon-*.svg with branded PNGs when ready.
