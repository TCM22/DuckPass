# Copy to `.env.local` and fill in values. This file is documentation only — not read at runtime.

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Use either legacy anon JWT or new publishable key (Connect dialog / API Keys)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Public origin for share links, QR payloads, and copy-to-clipboard (must match how you open the app in dev, or your deployed URL in prod)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Legacy alias — only used if NEXT_PUBLIC_SITE_URL is unset
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=DuckPass

# Supabase → Authentication → URL Configuration (required for email links):
# - Site URL: match the origin you use in the browser
# - Redirect URLs: list every origin you use, e.g. http://localhost:3000/** and your production domain
#   Include `/auth/callback` for sign-up confirmation and password reset (e.g. `http://localhost:3000/auth/callback**`).
# For dev tunnels, add your tunnel origin to Redirect URLs; `next.config.ts` already allows common tunnel hosts for HMR.

# Optional: salt for hashing client IPs in scan_events (see migrations/005_scan_events_privacy.sql)
# SCAN_IP_SALT=your-random-string

# PWA: service worker registers in production only (public/sw.js). Replace public/icon-*.svg with branded PNGs when ready.
